@inherits LayoutComponentBase

<MudThemeProvider Theme="@_potatoes"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <!-- App Bar -->
    <MudAppBar Color="Color.Primary" Fixed="true" Dense="@_dense" Elevation="@_elevation">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer"/>
        <MudText Typo="Typo.h5" Class="ml-3">Server Platform Web Panel</MudText>
        <MudSpacer/>


        <MudButton Href="/backend" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Info">Backend</MudButton>
        <MudButton Href="/logout" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Logout">Logout</MudButton>
    </MudAppBar>

    <!-- Drawer -->
    <MudDrawer @bind-Open="@_drawerOpen" Elevation="1" Variant="DrawerVariant.Responsive">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Server Platform</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Match="NavLinkMatch.Prefix" Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Match="NavLinkMatch.All" Href="/backend" Icon="@Icons.Material.Filled.Info">Backend</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <!-- Main Content -->
    <MudMainContent Class="pt-16 panel-content">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private readonly bool _dense = false;
    private readonly int _elevation = 4;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private readonly MudTheme _potatoes = new()
    {
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[]
                {
                    "Space Grotesk", "Helvetica", "Arial", "sans-serif"
                }
            }
        }
    };

}
